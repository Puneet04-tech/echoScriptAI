PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/echoscriptai?retryWrites=true&w=majority

# Speech-to-Text Provider Configuration
# Options: 'google' or 'deepspeech'
DEFAULT_STT_PROVIDER=google

# Google Cloud Speech-to-Text Configuration
# Path to Google Cloud service account JSON file
# or set GOOGLE_APPLICATION_CREDENTIALS environment variable
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json

# Mozilla DeepSpeech Configuration
# Path to DeepSpeech model directory containing output_graph.pbmm
DEEPSPEECH_MODEL_PATH=path/to/deepspeech/models
# Path to DeepSpeech scorer directory containing scorer.scorer (optional)
DEEPSPEECH_SCORER_PATH=path/to/deepspeech/models
